{
  "name": "lacuerda-downloader",
  "version": "1.0.0",
  "description": "Descargador y archivador de tablaturas de LaCuerda desde Wayback Machine",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "query": "node src/query.js",
    "crawl": "node src/crawl_alpha.js --start",
    "crawl:resume": "node src/crawl_alpha.js --resume",
    "crawl:retry": "node src/crawl_alpha.js --retry-failed",
    "build": "npm run build --prefix frontend",
    "dev": "npm run dev --prefix frontend & node src/server.js",
    "prod": "npm run build && node src/server.js"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "pg": "^8.21.0"
  }
}
